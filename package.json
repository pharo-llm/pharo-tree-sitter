{
  "name": "tree-sitter-pharo",
  "version": "0.1.0",
  "description": "Pharo grammar for tree-sitter",
  "repository": "https://github.com/kilian-kier/tree-sitter-pharo",
  "license": "MIT",
  "author": {
    "name": "Kilian Kier",
    "email": "kierkilian@gmail.com",
    "url": "https://github.com/kilian-kier/"
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "pharo"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "dependencies": {
    "node-addon-api": "^8.3.1",
    "node-gyp-build": "^4.8.4",
    "tree-sitter-cli": "^0.25.9"
  },
  "devDependencies": {
    "prebuildify": "^6.0.1"
  },
  "peerDependencies": {
    "tree-sitter": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "generate": "tree-sitter generate",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test bindings/node/*_test.js"
  }
}
